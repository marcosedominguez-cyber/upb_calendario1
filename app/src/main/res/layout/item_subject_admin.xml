<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_subject_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/upb_blue"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="SIS-301"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_subject"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Editar"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/upb_blue"
                android:textColor="@color/upb_blue"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_subject"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Eliminar"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="@color/error_red"
                android:textColor="@color/error_red"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_subject_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Programación Orientada a Objetos"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_subject_career"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ing. Sistemas"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:drawablePadding="4dp" />

            <TextView
                android:id="@+id/tv_subject_credits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/upb_blue_light"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="6 Cred."
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                tools:text="4 Cred." />

            <TextView
                android:id="@+id/tv_subject_classroom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#E8F0FE"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="@color/upb_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                tools:text="Aula B-2" />

            <TextView
                android:id="@+id/tv_subject_semester"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/upb_yellow"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Módulo 3"
                android:textColor="@color/upb_blue_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_subject_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Lunes a Viernes · 2 horas diarias"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>